[Unit]
Description=Realtor Agent dashboard
After=network-online.target realtor-agent-sync.service
Wants=network-online.target

[Service]
Type=simple
User=YOUR_LINUX_USER
WorkingDirectory=/path/to/Realtor_Agent
EnvironmentFile=/path/to/Realtor_Agent/.env
Environment=PYTHONUNBUFFERED=1
ExecStart=/path/to/Realtor_Agent/.venv/bin/realtor-agent --dashboard --host 0.0.0.0 --port 9421 --db-path /path/to/Realtor_Agent/data/realtor_agent.db
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
